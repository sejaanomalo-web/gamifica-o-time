# --- Database ----------------------------------------------------------------
# DATABASE_URL = Transaction Pooler (porta 6543) — para queries normais
# DIRECT_URL   = Direct Connection (porta 5432) — para migrations
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# --- Supabase Auth -----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
# Aceita os dois nomes (formato 2025+ recomendado: _PUBLISHABLE_KEY)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy (ainda funciona):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
# Legacy (ainda funciona):
# SUPABASE_SERVICE_ROLE_KEY=

# --- Web Push (VAPID) --------------------------------------------------------
# Gera com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:sejaanomalo@gmail.com

# --- Cron auth ---------------------------------------------------------------
# Vercel Cron envia `Authorization: Bearer <CRON_SECRET>` automaticamente.
CRON_SECRET=
